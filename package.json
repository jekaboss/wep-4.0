{
  "name": "wep-3.0",
  "version": "3.0.0",
  "description": "WEP-3.0 - Your Web Development Notebook",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "electron-dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "cheatsheet",
    "web-development",
    "notebook",
    "wep"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.wep.blocknot3",
    "productName": "WEP-3.0",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!.git/**"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/img/logo1.webp"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/img/logo1.webp"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/img/logo1.webp"
    }
  }
}
